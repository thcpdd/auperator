# Auperator 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# =============================================
# Redis 配置
# =============================================

# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（可选，如无密码可留空）
REDIS_PASSWORD=

# Redis 数据库编号（可选，默认 0）
REDIS_DB=0

# Redis 键前缀（用于避免 key 冲突）
REDIS_KEY_PREFIX=auperator:

# Redis Stream 名称（会自动添加前缀）
REDIS_STREAM_NAME=logs:main

# Redis 消费者组名称
REDIS_CONSUMER_GROUP=auperator-group

# =============================================
# 采集器配置
# =============================================

# 默认日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 批处理大小 (0 表示不批处理)
COLLECTOR_BATCH_SIZE=100

# 批处理超时（秒）
COLLECTOR_BATCH_TIMEOUT=5.0

# 最大重试次数
COLLECTOR_MAX_RETRIES=3

# 重试延迟（秒）
COLLECTOR_RETRY_DELAY=1.0

# =============================================
# Docker 配置
# =============================================

# Docker socket 路径
DOCKER_SOCKET=/var/run/docker.sock

# 默认采集容器日志行数 (0 表示全部)
DOCKER_TAIL=100

# 是否持续跟踪日志
DOCKER_FOLLOW=true

# =============================================
# 去重配置
# =============================================

# 是否启用日志去重（断点续传）
DEDUPLICATION_ENABLED=true

# 去重时间窗口（秒），默认 24 小时
# 用于控制去重记录的保留时间
DEDUPLICATION_WINDOW=86400

# 去重记录 TTL（秒），默认 7 天
# 超过此时间的去重记录将被自动清理
DEDUPLICATION_TTL=604800

# =============================================
# Agent 配置
# =============================================

# Agent 服务名称
AGENT_SERVICE=auperator

# 环境标识 (production/staging/development)
ENVIRONMENT=development
