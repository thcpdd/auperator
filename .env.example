# Auperator 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# =============================================
# OpenAI 配置
# =============================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=your_api_base
OPENAI_MODEL=glm-4.7

# =============================================
# Redis 配置
# =============================================

# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（可选，如无密码可留空）
REDIS_PASSWORD=

# Redis 数据库编号（可选，默认 0）
REDIS_DB=0

# Redis 键前缀（用于避免 key 冲突）
REDIS_KEY_PREFIX=auperator:

# Redis List 名称（Vector 写入，Auperator 消费）
REDIS_LIST_NAME=logs:main

# =============================================
# 消费者配置
# =============================================

# 批处理大小 (每次读取的消息数)
CONSUMER_BATCH_SIZE=1

# 阻塞超时（秒）
CONSUMER_BLOCK_TIMEOUT=5

# =============================================
# 通用配置
# =============================================

# 默认日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 环境标识 (production/staging/development)
ENVIRONMENT=development
